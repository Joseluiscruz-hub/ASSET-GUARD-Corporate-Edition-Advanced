{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "defaultProject": "asset-guard-advanced",
  "projects": {
    "asset-guard-advanced": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser-esbuild",
          "options": {
            "outputPath": "dist/asset-guard-advanced",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": [],
            "tsConfig": "tsconfig.json",
            "assets": [
              "src/favicon.png",
              "src/assets",
              "src/404.html",
              "src/.nojekyll"
            ],
            "styles": [
              "src/index.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "baseHref": "/ASSET-GUARD-Corporate-Edition-Advanced/"
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "asset-guard-advanced:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "asset-guard-advanced:build:production"
            }
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
